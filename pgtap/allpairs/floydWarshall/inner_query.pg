BEGIN;

UPDATE edges SET cost = sign(cost), reverse_cost = sign(reverse_cost);
SELECT plan(96);


SELECT style_dijkstra_no_id('pgr_floydwarshall(', ', true)');
SELECT style_dijkstra('pgr_floydwarshall(', ', true)');


SELECT finish();
ROLLBACK;
