BEGIN;

UPDATE edges SET cost = sign(cost), reverse_cost = sign(reverse_cost);
SELECT plan(102);

-- ONE MATRIX
SELECT style_astar('pgr_astarCostMatrix(', ', ARRAY[1,2,3,4], true)');

SELECT finish();
ROLLBACK;
