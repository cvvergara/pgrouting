BEGIN;

SELECT CASE WHEN min_version('3.2.0') THEN plan(11) ELSE PLAN(1) END;

SELECT single_path_types_check(
  'pgr_dijkstranear',
  '{directed,cap,global}'::TEXT[], '{bool,int8,bool}'::TEXT[],
   created_v => '3.2.0');

SELECT finish();
ROLLBACK;
