BEGIN;

UPDATE edges SET cost = sign(cost), reverse_cost = sign(reverse_cost);
SELECT plan(54);

DELETE FROM edges WHERE id > 10;

SELECT style_dijkstra('pgr_chinesepostmancost(', ')');

SELECT finish();
ROLLBACK;
