BEGIN;

SELECT CASE WHEN min_version('4.0.0') THEN plan(7) ELSE plan(6) END;

SELECT traversal_types_check('pgr_breadthfirstsearch', standard_v => '4.0.0');

SELECT finish();
ROLLBACK;
