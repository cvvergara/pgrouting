BEGIN;

SELECT CASE  WHEN min_version('4.0.0') THEN plan(7) WHEN min_version('3.2.0') THEN plan(6) ELSE plan(1) END;

SELECT traversal_types_check('pgr_depthfirstsearch', created_v=> '3.2.0', standard_v => '4.0.0');

SELECT finish();
ROLLBACK;
