BEGIN;

SELECT CASE WHEN min_version('4.0.0') THEN plan(13) WHEN min_version('3.2.0') THEN plan(12) ELSE PLAN(10) END;

SELECT single_path_types_check('pgr_dagshortestpath', '{}'::TEXT[], '{}'::TEXT[], standard_v => '4.0.0');

SELECT finish();
ROLLBACK;
