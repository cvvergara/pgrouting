BEGIN;

UPDATE edges SET cost = sign(cost), reverse_cost = sign(reverse_cost);
SELECT CASE WHEN min_version('3.2.0') THEN plan (81) ELSE plan(68) END;

SELECT * FROM flow_no_crash('pgr_maxFlow');

SELECT finish();
ROLLBACK;
