BEGIN;

UPDATE edges SET cost = sign(cost), reverse_cost = sign(reverse_cost);
SELECT plan(3);


SELECT has_function('pgr_version');
SELECT has_function('pgr_version', ARRAY[]::text[]);
SELECT function_returns('pgr_version', ARRAY[]::text[], 'text');

SELECT finish();
ROLLBACK;
