BEGIN;

SELECT CASE WHEN min_version('4.0.0') THEN plan(26) ELSE PLAN(4) END;

SELECT cost_types_check(
  'pgr_withpointscost',
  '{"",directed}'::TEXT[], '{bpchar,bool}'::TEXT[],
  standard_v => '4.0.0');

SELECT cost_types_check(
  'pgr_withpointscost',
  '{directed}'::TEXT[], '{bool}'::TEXT[],
  standard_v => '4.0.0');

SELECT finish();
ROLLBACK;
