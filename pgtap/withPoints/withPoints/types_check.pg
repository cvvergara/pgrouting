BEGIN;


SELECT CASE WHEN min_version('4.0.0') THEN plan(13) ELSE PLAN(1) END;

SELECT single_path_types_check(
  'pgr_withpoints',
  '{"",directed,details}'::TEXT[], '{bpchar,bool,bool}'::TEXT[],
  standard_v => '4.0.0');

SELECT finish();
ROLLBACK;
